{
  "name": "@nexus/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform desktop shell for Nexus",
  "author": "Ahmet Kilinc",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:electron\" \"bun run start\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "node scripts/bundle.mjs --watch",
    "start": "wait-on tcp:5173 file:dist/main/index.js && electron .",
    "build": "bun run build:renderer && bun run build:main",
    "build:renderer": "vite build",
    "build:main": "node scripts/bundle.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "bun test src",
    "topo": "true",
    "package": "bun run build && electron-builder",
    "verify:release": "node scripts/verify-release.mjs",
    "icons": "node scripts/build-icons.mjs",
    "package:local": "bun run build && electron-builder --dir -c.mac.notarize=false -c.mac.identity=null"
  },
  "build": {
    "appId": "dev.nexus.app",
    "productName": "Nexus",
    "publish": null,
    "afterPack": "scripts/after-pack.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "package.json",
      "!node_modules",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "dist/runtime/**",
      "node_modules/node-pty/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "dmg": {
      "sign": true,
      "writeUpdateInfo": false
    },
    "afterAllArtifactBuild": "scripts/notarize-dmg.cjs"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@electron/fuses": "^2.1.3",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource/fira-code": "5.2.7",
    "@hugeicons-pro/core-stroke-rounded": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@nexus/protocol": "workspace:*",
    "@nexus/runtime": "workspace:*",
    "@pierre/diffs": "^1.2.12",
    "@pierre/trees": "^1.0.0-beta.5",
    "@tailwindcss/vite": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "electron": "43",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-harden": "1.1.8",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "4.3.1",
    "streamdown": "2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "unified": "^11",
    "vite": "^6.1.0",
    "wait-on": "^8.0.2"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  }
}
