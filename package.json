{
  "name": "nexus",
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.7.3"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "audit:deps": "node scripts/audit-deps.mjs",
    "check": "turbo run typecheck test build && bun run lint && bun run format:check && bun run audit:deps",
    "package": "turbo run package"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "electron",
    "esbuild",
    "node-pty"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "tar": "7.5.22"
  },
  "dependencies": {
    "tar": "7.5.22"
  }
}
